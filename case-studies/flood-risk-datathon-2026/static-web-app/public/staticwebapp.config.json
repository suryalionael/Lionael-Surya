{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/data/*", "/*.{css,js,json}"]
  },
  "globalHeaders": {
    "Cache-Control": "no-cache"
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "routes": [
    {
      "route": "/data/*",
      "headers": {
        "Cache-Control": "public, max-age=300"
      }
    }
  ]
}
